/*
  # Content Security Policy - Protección contra XSS y inyección de código
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.voiceflow.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.voiceflow.com; font-src 'self' https://fonts.gstatic.com https://cdn.voiceflow.com; img-src 'self' data: https: blob:; connect-src 'self' https://rlhdbfcnxhafvmdmjzrn.supabase.co https://www.google-analytics.com https://general-runtime.voiceflow.com https://runtime-api.voiceflow.com https://api.voiceflow.com; frame-src https://cdn.voiceflow.com; worker-src blob: https://cdn.voiceflow.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';
  
  # Prevenir sniffing de contenido malicioso
  X-Content-Type-Options: nosniff
  
  # Protección contra clickjacking
  X-Frame-Options: DENY
  
  # Control de información de referencia
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Forzar HTTPS (HSTS)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Protección XSS legacy (para navegadores antiguos)
  X-XSS-Protection: 1; mode=block
  
  # Control de funciones del navegador
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  
  # CORS Headers
  Access-Control-Allow-Origin: https://nodeslabs.com
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization

/ai.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS